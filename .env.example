# ============================================================
# LocalUp Environment Variables
# Copy to .env and fill in your values.
#
# Server-side variables (no PUBLIC_ prefix) are read at runtime
# from process.env. That means you can swap credentials by
# restarting the standalone Node server without rebuilding.
# ============================================================

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Calendar — OAuth 2.0 refresh token
# 1. Create OAuth 2.0 Client ID in Google Cloud Console (Web application)
# 2. Generate refresh token via OAuth Playground with scope:
#    https://www.googleapis.com/auth/calendar
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REFRESH_TOKEN=1//xxxx
GOOGLE_CALENDAR_ID=primary

# Resend — transactional email
RESEND_API_KEY=re_xxxx

# Email sender identity
EMAIL_FROM=LocalUp <hello@localup.hu>
EMAIL_REPLY_TO=peter@localup.hu

# Admin notification email
ADMIN_EMAIL=admin@localup.io

# Booking management token encryption (32 bytes as 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOOKING_TOKEN_ENCRYPTION_KEY=

# Cancel / reschedule cutoff hours
AUDIT_CANCEL_CUTOFF_HOURS=12
AUDIT_RESCHEDULE_CUTOFF_HOURS=12
AUDIT_MAX_RESCHEDULES=2

# Site URL — used for email links, tracking sourceUrl, and manage/cancel/reschedule URLs.
# In development: http://localhost:4321
# In production: https://localup.hu
SITE_URL=http://localhost:4321
