---
import Container from '../layout/Container.astro';
import Section from '../layout/Section.astro';
import Button from '../ui/Button.astro';
import { finalCtaContent } from '../../data/homepage';

const { eyebrow, title, description, primaryCta, secondaryCta, trustBadges } = finalCtaContent;
---

<Section variant="transparent" padding="lg" class="overflow-x-clip" id="audit">
  <Container>
    <div class="bg-bg-dark border border-white/5 rounded-[32px] p-[32px] sm:p-[60px] lg:p-[80px] min-h-[600px] flex items-center relative overflow-clip w-full shadow-hero">
      
      <!-- Left Content Column -->
      <div class="flex flex-col gap-[40px] items-start relative z-10 w-full lg:max-w-[620px]">
        
        <!-- Text Group -->
        <div class="flex flex-col gap-[24px] items-start w-full">
          <!-- Eyebrow Tag -->
          <div class="bg-accent-soft px-[16px] py-[8px] rounded-[12px] flex gap-[8px] items-center text-bg-dark select-none">
            <img src="/assets/icons/rocket.svg" alt="" width="14" height="14" class="size-[14px]" />
            <span class="text-[11px] font-semibold uppercase tracking-wider leading-none">
              {eyebrow}
            </span>
          </div>

          <!-- Main Heading -->
          <h2 class="font-medium text-[40px] sm:text-[48px] lg:text-[56px] leading-[1.1] text-white tracking-[-2px] sm:tracking-[-3px] max-w-[560px]">
            {title.split('\n').map((line, i) => (
              <>
                {line}
                {i < title.split('\n').length - 1 && <br class="hidden sm:inline" />}
              </>
            ))}
          </h2>

          <!-- Description -->
          <p class="font-normal text-[18px] sm:text-[20px] leading-[1.6] text-white/70 tracking-[-0.5px] max-w-[600px]">
            {description.split('\n').map((line, i) => (
              <>
                {line}
                {i < description.split('\n').length - 1 && <br class="hidden sm:inline" />}
              </>
            ))}
          </p>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-[16px] w-full sm:w-auto">
          <Button variant="accent-primary" href={primaryCta.href} class="w-full sm:w-auto">
            <span>{primaryCta.label}</span>
            <img src="/assets/icons/arrow-right.svg" alt="" width="16" height="16" class="size-[16px] shrink-0" />
          </Button>
        </div>

        <!-- Trust Badges Row -->
        <div class="flex flex-col sm:flex-row gap-y-[12px] sm:gap-x-[32px] items-start sm:items-center w-full mt-[8px]">
          {trustBadges.map((badge, index) => (
            <>
              {index > 0 && <div class="hidden sm:block h-[24px] w-px bg-white/20"></div>}
              <div class="flex gap-[12px] items-center">
                <div class="bg-white/10 border border-accent-soft flex items-center justify-center rounded-[8px] shrink-0 size-[20px]">
                  <img src="/assets/icons/check-yellow.svg" alt="" width="10" height="10" class="size-[10px]" />
                </div>
                <span class="text-[14px] font-medium text-white whitespace-nowrap">{badge}</span>
              </div>
            </>
          ))}
        </div>

      </div>

      <!-- Right Graphic Overlay -->
      <div class="absolute left-[20%] lg:left-[40%] top-[-131px] size-[898px] pointer-events-none select-none z-0 opacity-10 lg:opacity-100">
        <img src="/assets/images/service-mockup.png" alt="" width="898" height="898" class="size-full object-contain" loading="lazy" />
      </div>

    </div>
  </Container>
</Section>
