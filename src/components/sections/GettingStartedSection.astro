---
import Container from '../layout/Container.astro';
import Section from '../layout/Section.astro';
import SectionHeader from '../layout/SectionHeader.astro';
import { gettingStartedContent } from '../../data/homepage';

const { eyebrow, title, description, steps, bottomCard } = gettingStartedContent;

// Icon mapping for each step
const stepIcons: Record<string, string> = {
  '01': '/assets/icons/search.svg',
  '02': '/assets/icons/layout.svg',
  '03': '/assets/icons/chart-line.svg',
};

// Icon alt texts
const stepIconAlts: Record<string, string> = {
  '01': 'Search',
  '02': 'Layout',
  '03': 'Chart',
};

// Raw SVG for eyebrow icon (rocket)
const eyebrowIconSvg = `
<svg viewBox="0 0 14 14" fill="none" class="size-[14px]" xmlns="http://www.w3.org/2000/svg">
  <path d="M12.8333 1.16667C12.8333 1.16667 9.91667 1.75 8.16667 3.5C6.41667 5.25 6.41667 7.58333 6.41667 7.58333C6.41667 7.58333 8.75 7.58333 10.5 5.83333C12.25 4.08333 12.8333 1.16667 12.8333 1.16667Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M7.58333 6.41667C7.58333 6.41667 5.25 6.41667 3.5 8.16667C1.75 9.91667 1.16667 12.8333 1.16667 12.8333C1.16667 12.8333 4.08333 12.25 5.83333 10.5C7.58333 8.75 7.58333 6.41667 7.58333 6.41667Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M11.6667 5.25L8.75 2.33333" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M5.25 11.6667L2.33333 8.75" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
`;
---

<Section variant="transparent" padding="lg" id="how-it-works">
  <Container>
    <!-- Section Header -->
    <div class="animate-on-scroll animate-fade-up">
      <SectionHeader
        eyebrow={eyebrow}
        eyebrowIcon={eyebrowIconSvg}
        title={title}
        description={description}
        align="center"
      />
    </div>

    <!-- Steps Timeline -->
    <div class="relative mt-[60px]">
      <!-- Desktop connecting line: runs behind the cards at icon level -->
      <div class="hidden lg:block absolute left-[calc(16.666%+48px)] right-[calc(16.666%+48px)] top-[54px] h-px bg-border-subtle pointer-events-none" aria-hidden="true">
      </div>
      <!-- Dots at gap midpoints -->
      <div class="hidden lg:block absolute left-[33.333%] top-[54px] -translate-x-1/2 -translate-y-1/2 size-[10px] rounded-full bg-accent-strong pointer-events-none" aria-hidden="true">
      </div>
      <div class="hidden lg:block absolute left-[66.666%] top-[54px] -translate-x-1/2 -translate-y-1/2 size-[10px] rounded-full bg-accent-strong pointer-events-none" aria-hidden="true">
      </div>

      <!-- Mobile vertical line (left side) -->
      <div class="lg:hidden absolute left-[22px] top-[56px] bottom-[56px] w-px bg-border-subtle pointer-events-none" aria-hidden="true">
      </div>
      <!-- Mobile dots -->
      <div class="lg:hidden absolute left-[22px] top-[50%] -translate-x-1/2 -translate-y-1/2 size-[8px] rounded-full bg-accent-strong pointer-events-none" aria-hidden="true">
      </div>

      <div class="flex flex-col lg:flex-row items-stretch gap-[24px] lg:gap-[32px] w-full">
        {steps.map((step, index) => {
          const iconPath = stepIcons[step.number] ?? '/assets/icons/search.svg';
          const iconAlt = stepIconAlts[step.number] ?? 'Step icon';
          return (
            <div class={`relative flex flex-col bg-white border border-border-subtle rounded-2xl p-[32px] md:p-[40px] shadow-card flex-1 group hover:shadow-panel transition-shadow duration-300 animate-on-scroll animate-fade-up animate-delay-${index + 1}`}>
              <!-- Icon row -->
              <div class="flex items-center mb-[24px]">
                <div class="bg-bg-muted flex items-center justify-center rounded-xl shrink-0 size-[44px]">
                  <img src={iconPath} alt={iconAlt} class="size-[20px]" />
                </div>
              </div>

              <!-- Title + description -->
              <div class="flex flex-col gap-[10px] mb-auto">
                <h3 class="font-semibold text-[20px] tracking-[-0.3px] leading-[1.3] text-text-primary">
                  {step.title}
                </h3>
                <p class="font-normal text-[15px] text-text-secondary leading-[1.55]">
                  {step.description}
                </p>
              </div>

              <!-- Time badge -->
              <div class="mt-[28px] flex gap-[8px] items-center px-[12px] py-[6px] bg-bg-muted rounded-pill text-text-primary w-fit">
                <img src={step.badgeIcon} alt="" class="size-[14px] opacity-60" />
                <span class="text-[13px] font-medium leading-none whitespace-nowrap">{step.badge}</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Bottom Features Card - Dark Green -->
    {bottomCard && (
      <div class="bg-bg-dark border border-border-dark-subtle flex flex-col md:flex-row gap-[20px] md:gap-[32px] items-start md:items-center p-[24px] md:px-[32px] rounded-2xl w-full justify-between shadow-hero mt-[40px]">
        <div class="flex gap-[16px] items-center">
          <div class="bg-bg-icon-dark flex items-center justify-center rounded-2xl shrink-0 size-[48px]">
            <img src="/assets/icons/bar-chart.svg" alt="Bar chart" class="size-[20px]" />
          </div>
          <div class="flex flex-col gap-[2px]">
            <h4 class="font-semibold text-[16px] tracking-[-0.3px] text-white leading-snug">
              {bottomCard.heading}
            </h4>
            <p class="font-normal text-[14px] text-white/65 leading-relaxed">
              {bottomCard.description}
            </p>
          </div>
        </div>

        <div class="flex flex-wrap gap-[16px] md:gap-[28px] items-center">
          {bottomCard.badges.map((badge: string) => (
            <div class="flex gap-[10px] items-center shrink-0">
              <div class="bg-bg-icon-dark border border-accent-strong flex items-center justify-center rounded-md shrink-0 size-[18px]">
                <svg class="size-[10px]" fill="none" viewBox="0 0 10 10" stroke="currentColor" stroke-width="1.5" color="var(--color-accent-strong)">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3 3 5-6" />
                </svg>
              </div>
              <span class="text-[14px] font-medium text-white/75 whitespace-nowrap">{badge}</span>
            </div>
          ))}
        </div>
      </div>
    )}
  </Container>
</Section>
