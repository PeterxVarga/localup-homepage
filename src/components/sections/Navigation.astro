---
import Button from '../ui/Button.astro';
import { navLinks } from '../../data/homepage';
---

<header class="nav-animate w-full bg-bg-page border-b border-transparent py-[14px] md:py-[18px] sticky top-0 z-50 backdrop-blur-sm transition-all duration-500 ease-[cubic-bezier(0.25,1,0.5,1)]">
  <div class="mx-auto max-w-[1360px] px-[24px] sm:px-[32px] md:px-[40px] w-full flex items-center justify-between">
    <a href="/" class="text-[26px] font-medium tracking-[-0.5px] text-text-primary hover:opacity-90 transition-opacity">
      LocalUp
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-[40px]" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-[16px] text-text-primary hover:text-bg-dark transition-colors font-normal"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <Button
      href="/audit?cta_location=nav"
      variant="primary"
      class="hidden md:inline-flex whitespace-nowrap !py-[14px] !px-[22px]"
    >
      Get free audit
    </Button>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="block md:hidden text-text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-text-primary rounded-[8px] p-1"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Dropdown -->
  <div
    id="mobile-menu"
    class="hidden md:hidden w-full bg-white border-t border-border-subtle mt-[16px] px-[24px] py-[20px]"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <nav class="flex flex-col gap-[16px]">
      {navLinks.map((link) => (
        <a href={link.href} class="text-[16px] text-text-primary hover:text-bg-dark transition-colors font-normal py-1">
          {link.label}
        </a>
      ))}
    </nav>
    <Button
      href="/audit?cta_location=nav"
      variant="primary"
      class="mt-[20px] w-full !py-[14px] !px-[22px]"
    >
      Get free audit
    </Button>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');
  const header = document.querySelector('header') as HTMLElement | null;

  // Remove entrance animation class once it finishes, so the transform
  // is freed up for the sticky scroll behavior (hide/show on scroll).
  if (header) {
    header.addEventListener('animationend', (e) => {
      if (e.animationName === 'nav-slide-down') {
        header.classList.remove('nav-animate');
      }
    });
  }

  // Mobile menu toggle
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Smart sticky header (hide on scroll down, show on scroll up, dynamic border)
  if (header) {
    let lastScrollY = window.scrollY;

    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;

      // 1. Dynamic border and shadow
      if (currentScrollY > 15) {
        header.classList.add('border-border-subtle', 'shadow-sm');
        header.classList.remove('border-transparent');
      } else {
        header.classList.remove('border-border-subtle', 'shadow-sm');
        header.classList.add('border-transparent');
      }

      // 2. Hide on scroll down, show on scroll up
      // Mobile menu should be closed when scrolling down
      const isMobileMenuOpen = menu && !menu.classList.contains('hidden');

      if (currentScrollY > lastScrollY && currentScrollY > 80 && !isMobileMenuOpen) {
        // Scrolling down -> Hide header
        header.classList.add('-translate-y-full');
      } else {
        // Scrolling up -> Show header
        header.classList.remove('-translate-y-full');
      }

      lastScrollY = currentScrollY;
    }, { passive: true });
  }
</script>
