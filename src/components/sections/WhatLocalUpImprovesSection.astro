---
import Container from '../layout/Container.astro';
import Section from '../layout/Section.astro';
import SectionHeader from '../layout/SectionHeader.astro';
import Card from '../ui/Card.astro';

// Raw SVG for eyebrow icon (chart-line)
const eyebrowIconSvg = `
<svg viewBox="0 0 17 17" fill="none" class="size-[14px]" xmlns="http://www.w3.org/2000/svg">
  <path d="M2.125 2.125V13.4583C2.125 13.8341 2.27426 14.1944 2.53993 14.4601C2.80561 14.7257 3.16594 14.875 3.54167 14.875H14.875" stroke="currentColor" stroke-opacity="0.9" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M12.75 12.0417V6.375" stroke="currentColor" stroke-opacity="0.9" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M9.20833 12.0417V3.54167" stroke="currentColor" stroke-opacity="0.9" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M5.66667 12.0417V9.91667" stroke="currentColor" stroke-opacity="0.9" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
`;
---

<Section variant="transparent" padding="lg" id="solutions" class="overflow-x-clip">
  <Container>
    <!-- Section Header -->
    <div class="animate-on-scroll animate-fade-up">
      <SectionHeader
        eyebrow="What LocalUp Improves"
        eyebrowIcon={eyebrowIconSvg}
        title="Improve the places customers check before they contact you."
        description="LocalUp helps service businesses look clearer, more trustworthy, and easier to contact across the moments that influence local customers most."
        align="center"
      />
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-[16px] mt-[60px] w-full">
      
      <!-- Card 1: Website clarity (Dark) -->
      <Card variant="dark" class="animate-on-scroll animate-fade-up animate-delay-1 flex flex-col md:flex-row gap-[32px] justify-between items-start md:items-stretch p-[32px] md:p-[40px] md:h-[280px]">
        <div class="flex flex-col justify-between flex-grow h-full max-w-[280px]">
          <div class="bg-[#22423f] flex items-center justify-center rounded-[8px] shrink-0 size-[36px] mb-[24px]">
            <img src="/assets/icons/circle-x.svg" alt="X icon" class="size-[18px]" />
          </div>
          <div>
            <h3 class="font-medium text-[26px] tracking-[-0.5px] leading-tight text-white mb-[10px]">
              Website clarity
            </h3>
            <p class="font-normal text-[15px] text-white/70 leading-[1.5]">
              Make your site clear, credible, and easy to act on.
            </p>
          </div>
        </div>

        <!-- Browser Mockup Visual -->
        <div class="flex flex-col items-center justify-center shrink-0 w-full md:w-[260px] h-full self-center">
          <div class="bg-bg-dark border border-white/10 flex flex-col h-[200px] w-full rounded-[12px] shadow-card overflow-clip">
            <!-- Mock Header -->
            <div class="bg-white/5 flex gap-[9px] h-[28px] items-center px-[10px] py-[8px] w-full border-b border-white/5">
              <img src="/assets/icons/browser-dots.svg" alt="Browser controls" class="h-[6px] w-[30px]" />
              <div class="bg-white/10 h-[16px] rounded-[4px] w-[140px]" />
            </div>
            <!-- Mock Body -->
            <div class="flex flex-col gap-[10px] p-[14px]">
              <div class="flex gap-[10px] items-center">
                <div class="bg-accent-strong/10 rounded-[4px] shrink-0 size-[36px]" />
                <div class="flex flex-col gap-[6px] flex-grow">
                  <div class="bg-white/20 h-[5px] rounded-[4px] w-full" />
                  <div class="bg-white/10 h-[5px] rounded-[4px] w-[100px]" />
                </div>
              </div>
              <div class="bg-white/10 h-[5px] rounded-[4px] w-full" />
              <div class="bg-white/5 h-[5px] rounded-[4px] w-[180px]" />
              <div class="bg-white/5 h-[5px] rounded-[4px] w-full" />
              <div class="bg-white/5 h-[5px] rounded-[4px] w-[160px]" />
              <!-- Buttons -->
              <div class="flex gap-[8px] pt-[10px]">
                <div class="bg-accent-strong h-[22px] rounded-[4px] w-[95px]" />
                <div class="bg-white/10 h-[22px] rounded-[4px] w-[75px]" />
              </div>
            </div>
          </div>
        </div>
      </Card>

      <!-- Card 2: Google presence (Light) -->
      <Card variant="light" class="animate-on-scroll animate-fade-up animate-delay-2 flex flex-col md:flex-row gap-[32px] justify-between items-start md:items-stretch p-[32px] md:p-[40px] md:h-[280px]">
        <div class="flex flex-col justify-between flex-grow h-full max-w-[280px]">
          <div class="bg-accent-surface flex items-center justify-center rounded-[8px] shrink-0 size-[36px] mb-[24px]">
            <img src="/assets/icons/circle-x-2.svg" alt="X icon" class="size-[18px]" />
          </div>
          <div>
            <h3 class="font-medium text-[26px] tracking-[-0.5px] leading-tight text-text-primary mb-[10px]">
              Google presence
            </h3>
            <p class="font-normal text-[15px] text-text-secondary leading-[1.5]">
              Show up with accurate, useful information when people search.
            </p>
          </div>
        </div>

        <!-- Google Presence Visual -->
        <div class="flex items-center justify-center shrink-0 w-full md:w-[220px] h-full self-center overflow-hidden">
          <img 
            src="/assets/images/google-presence-preview.png" 
            alt="Google presence preview map and profile mock" 
            class="h-[208px] w-auto max-w-full object-contain" 
          />
        </div>
      </Card>

      <!-- Card 3: Reviews & reputation (Light) -->
      <Card variant="light" class="animate-on-scroll animate-fade-up animate-delay-3 flex flex-col md:flex-row gap-[32px] justify-between items-start md:items-stretch p-[32px] md:p-[40px] md:h-[260px]">
        <div class="flex flex-col justify-between flex-grow h-full max-w-[280px]">
          <div class="bg-accent-surface flex items-center justify-center rounded-[8px] shrink-0 size-[36px] mb-[24px]">
            <svg class="size-[18px]" fill="none" viewBox="0 0 18 18" stroke="currentColor" stroke-width="1.5" color="var(--color-bg-dark)">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 1.5l2.09 4.26 4.66.68-3.37 3.28.8 4.64L9 12.21l-4.18 2.15.8-4.64-3.37-3.28 4.66-.68L9 1.5z" />
            </svg>
          </div>
          <div>
            <h3 class="font-medium text-[26px] tracking-[-0.5px] leading-tight text-text-primary mb-[10px]">
              Reviews & reputation
            </h3>
            <p class="font-normal text-[15px] text-text-secondary leading-[1.5]">
              Build trust before people decide who to contact.
            </p>
          </div>
        </div>

        <!-- Reviews Visual -->
        <div class="flex items-center justify-center shrink-0 w-full md:w-[250px] h-full self-center">
          <div class="bg-white border border-border-subtle p-[16px] rounded-[12px] shadow-small w-full">
            <img src="/assets/icons/five-stars.svg" alt="Five stars" class="h-[12px] w-[73px] mb-[12px]" />
            <div class="flex flex-col gap-[8px]">
              <!-- Row 1 -->
              <div class="flex gap-[8px] items-center py-[2px]">
                <div class="size-[30px] rounded-full border border-bg-card-warm overflow-hidden shrink-0">
                  <img src="/assets/images/avatar-1.png" alt="Customer" class="size-full object-cover" />
                </div>
                <div class="flex flex-col gap-[6px] flex-grow">
                  <div class="bg-[#e5e7eb] h-[6px] rounded-[4px] w-[99px]" />
                  <div class="bg-[#e5e7eb] h-[6px] rounded-[4px] w-[76px]" />
                </div>
              </div>
              <!-- Row 2 -->
              <div class="flex gap-[8px] items-center py-[2px]">
                <div class="size-[30px] rounded-full border border-bg-card-warm overflow-hidden shrink-0">
                  <img src="/assets/images/avatar-2.png" alt="Customer" class="size-full object-cover" />
                </div>
                <div class="flex flex-col gap-[6px] flex-grow">
                  <div class="bg-[#e5e7eb] h-[6px] rounded-[4px] w-[97px]" />
                  <div class="bg-[#e5e7eb] h-[6px] rounded-[4px] w-[70px]" />
                </div>
              </div>
              <!-- Row 3 -->
              <div class="flex gap-[8px] items-center py-[2px]">
                <div class="size-[30px] rounded-full border border-bg-card-warm overflow-hidden shrink-0">
                  <img src="/assets/images/avatar-3.png" alt="Customer" class="size-full object-cover" />
                </div>
                <div class="flex flex-col gap-[6px] flex-grow">
                  <div class="bg-[#e5e7eb] h-[6px] rounded-[4px] w-[96px]" />
                  <div class="bg-[#e5e7eb] h-[6px] rounded-[4px] w-[86px]" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </Card>

      <!-- Card 4: Enquiry path (Light) -->
      <Card variant="light" class="animate-on-scroll animate-fade-up animate-delay-4 flex flex-col md:flex-row gap-[32px] justify-between items-start md:items-stretch p-[32px] md:p-[40px] md:h-[260px]">
        <div class="flex flex-col justify-between flex-grow h-full max-w-[280px]">
          <div class="bg-accent-surface flex items-center justify-center rounded-[8px] shrink-0 size-[36px] mb-[24px]">
            <img src="/assets/icons/phone.svg" alt="Phone icon" class="size-[18px]" />
          </div>
          <div>
            <h3 class="font-medium text-[26px] tracking-[-0.5px] leading-tight text-text-primary mb-[10px]">
              Enquiry path
            </h3>
            <p class="font-normal text-[15px] text-text-secondary leading-[1.5]">
              Make calls, messages, and bookings easier to take.
            </p>
          </div>
        </div>

        <!-- Enquiry Mock Visual -->
        <div class="flex items-center justify-center shrink-0 w-full md:w-[220px] h-full self-center">
          <div class="flex flex-col gap-[8px] w-full">
            <!-- Call button -->
            <div class="bg-bg-dark text-white rounded-[8px] flex justify-between items-center px-[14px] py-[12px] shadow-small">
              <span class="font-medium text-[13px]">Call now</span>
              <img src="/assets/icons/phone-solid.svg" alt="Phone" class="size-[14px] invert" />
            </div>
            <!-- Message us -->
            <div class="bg-white text-text-primary border border-border-subtle rounded-[8px] flex justify-between items-center px-[14px] py-[11px] shadow-small">
              <span class="font-normal text-[13px]">Message us</span>
              <img src="/assets/icons/chevron-right.svg" alt="Arrow" class="size-[14px]" />
            </div>
            <!-- Quote -->
            <div class="bg-white text-text-primary border border-border-subtle rounded-[8px] flex justify-between items-center px-[14px] py-[11px] shadow-small">
              <span class="font-normal text-[13px]">Request a quote</span>
              <img src="/assets/icons/chevron-right.svg" alt="Arrow" class="size-[14px]" />
            </div>
            <!-- Book online -->
            <div class="bg-white text-text-primary border border-border-subtle rounded-[8px] flex justify-between items-center px-[14px] py-[11px] shadow-small">
              <span class="font-normal text-[13px]">Book online</span>
              <img src="/assets/icons/chevron-right.svg" alt="Arrow" class="size-[14px]" />
            </div>
          </div>
        </div>
      </Card>

    </div>
  </Container>
</Section>
