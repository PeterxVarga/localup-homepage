---
interface Props {
  title: string;
  description: string;
  icon: string;
  class?: string;
}

const { title, description, icon, class: className = '' } = Astro.props;
---

<div class={`flex gap-[20px] items-start p-[24px] w-full min-w-0 ${className}`}>
  <div class="bg-[#f0f2e8] flex items-center justify-center rounded-[8px] shrink-0 size-[40px] text-bg-dark">
    <img src={icon} alt="" class="size-[20px]" aria-hidden="true" />
  </div>
  <div class="flex flex-col gap-[8px] items-start flex-grow">
    <h4 class="font-semibold leading-[1.3] text-text-primary text-[16px]">
      {title}
    </h4>
    <p class="font-normal leading-[1.5] text-[13px] text-text-secondary">
      {description}
    </p>
  </div>
</div>
