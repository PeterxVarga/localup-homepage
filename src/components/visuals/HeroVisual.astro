          </p>
        </div>
      </Card>

      <!-- DUPLICATED SET FOR SEAMLESS LOOP -->
      
      <!-- Card 4 -->
      <Card variant="accent-lavender" class="w-[320px] shrink-0 h-[240px] p-[20px] flex flex-col justify-between text-bg-dark">
        <div class="flex gap-[8px] items-center">
