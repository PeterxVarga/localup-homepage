</div>

<script>
  const tracks = document.querySelectorAll('.animate-marquee-left, .animate-marquee-right');
  
  tracks.forEach((track) => {
    let rate = 1;
    let targetRate = 1;
    let anims: Animation[] = [];
    let frameId: number | null = null;

    const updateAnimations = () => {
      // Get all active animations on this element (using standard getAnimations)
      anims = track.getAnimations() as Animation[];
    };

    const tick = () => {
      if (Math.abs(rate - targetRate) > 0.01) {
        rate += (targetRate - rate) * 0.08; // smooth exponential decay (lerp)
        anims.forEach((anim) => {
          anim.playbackRate = rate;
        });
        frameId = requestAnimationFrame(tick);
      } else {
        rate = targetRate;
        anims.forEach((anim) => {
          anim.playbackRate = rate;
        });
        if (frameId) {
          cancelAnimationFrame(frameId);
          frameId = null;
        }
      }
    };

    // We bind hover listeners to the parent track wrapper to trigger smooth pause/play
    const triggerArea = track.parentElement;
    if (triggerArea) {
      triggerArea.addEventListener('mouseenter', () => {
        updateAnimations();
        targetRate = 0; // target speed is 0 (paused)
        if (!frameId) {
          frameId = requestAnimationFrame(tick);
        }
      });

      triggerArea.addEventListener('mouseleave', () => {
        updateAnimations();
        targetRate = 1; // target speed is 1 (normal)
        if (!frameId) {
          frameId = requestAnimationFrame(tick);
        }
      });
    }
  });
</script>
