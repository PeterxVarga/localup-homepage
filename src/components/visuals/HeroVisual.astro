        <div class="absolute inset-0 z-0">
          <img 
            src="/assets/images/owners-strategy.png" 
            alt="" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        </div>
        <div class="relative z-10 p-[20px] flex gap-[12px] items-center">
          <div class="bg-[#e2e67f] flex items-center justify-center rounded-[8px] shrink-0 size-[36px]">
            <img src="/assets/icons/chart-arrow.svg" alt="" width="22" height="22" class="size-[22px]" />
          </div>
          <div>
            <p class="font-medium text-[18px] leading-[1.2] text-white tracking-[-0.5px]">
              Real strategies.<br/>Real results.
            </p>
          </div>
        </div>
      </Card>

      <!-- Card 2: Quote -->
      <Card variant="warm" class="w-[340px] shrink-0 h-[290px] p-[24px] flex flex-col justify-between text-bg-dark">
        <div class="size-[24px] shrink-0">
          <img src="/assets/icons/quote.svg" alt="" width="24" height="24" class="w-full h-full" />
        </div>
        <div class="flex-grow flex items-center">
          <p class="font-normal leading-[1.5] text-[16px] sm:text-[18px] tracking-[-0.5px]">
            "LocalUp made it easy to get found in more searches, earn better reviews, and turn interest into bookings."
          </p>
        </div>
        <div class="w-full h-px bg-[#d0d0c9]/60"></div>
      </Card>

      <!-- Card 3: Rank Tracking (Lavender Style) -->
      <Card variant="accent-lavender" class="w-[260px] shrink-0 h-[290px] p-[24px] flex flex-col justify-between text-bg-dark">
        <div class="flex gap-[10px] items-center">
          <div class="bg-bg-dark/10 flex items-center justify-center rounded-[6px] shrink-0 size-[32px] text-bg-dark">
            <img src="/assets/icons/trending-up.svg" alt="" width="18" height="18" class="size-[18px]" />
          </div>
          <span class="text-bg-dark text-[11px] font-semibold tracking-wide uppercase">Rank tracking</span>
        </div>
        <div>
