---
import Card from '../ui/Card.astro';
import CheckItem from '../ui/CheckItem.astro';
---

<div class="bg-bg-dark py-[28px] md:py-[32px] w-full max-w-full md:rounded-l-[20px] md:rounded-r-none rounded-[20px] shadow-panel overflow-hidden marquee-container flex flex-col gap-[20px]" data-name="HeroVisual">
  
  <!-- Row 1: Slides Left (Height matches previous version: 290px) -->
  <div class="flex overflow-hidden relative w-full" aria-hidden="true">
    <div class="flex gap-[16px] animate-marquee-left pl-[16px]">
      
      <!-- Card 1: Image Strategy -->
